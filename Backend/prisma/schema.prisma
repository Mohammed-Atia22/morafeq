generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                   @id @default(autoincrement()) @db.UnsignedInt
  email                String                @unique @db.VarChar(255)
  passwordHash         String?               @db.VarChar(255)
  firstName            String                @db.VarChar(100)
  lastName             String                @db.VarChar(100)
  age                  Int?                  @db.UnsignedInt
  avatarUrl            String?               @db.VarChar(500)
  phone                String?               @db.Text
  phoneCountry         String?               @db.VarChar(2)
  phoneCountryCode     String?               @db.VarChar(5)
  phoneHash            String?               @unique @db.VarChar(64)
  role                 UserRole              @default(GUEST)
  onboardingCompleted  Boolean               @default(false)
  gender               genderTypes           @default(male)
  bio                  String?               @db.Text
  isVerified           Boolean               @default(false)
  verificationStatus   VerificationStatus    @default(NOT_STARTED)
  trustScore           Int                   @default(0) @db.UnsignedInt
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  bookings             Booking[]
  listings             Listing[]
  reviewsWritten       Review[]              @relation("ReviewsWritten")
  reviewsReceived      Review[]              @relation("ReviewsReceived")
  otps                 OTP[]
  notifications        Notification[]
  roommateProfile      RoommateProfile?
  guestConversations   Conversation[]        @relation("GuestConversations")
  hostConversations    Conversation[]        @relation("HostConversations")
  sentMessages         Message[]             @relation("MessageSender")
  verification         Verification?
  disputeConversations DisputeConversation[] @relation("DisputeConversationParticipant")
  disputeMessages      DisputeMessage[]      @relation("DisputeMessageSender")
  favorites            Favorite[]
  preferences          UserPreference[]

  @@index([email])
  @@index([phoneCountry])
  @@index([phoneCountryCode])
  @@map("users")
}

model RoommateProfile {
  id     Int @id @default(autoincrement()) @db.UnsignedInt
  userId Int @unique @db.UnsignedInt

  occupationType RoommateOccupationType?

  university   String? @db.VarChar(150)
  faculty      String? @db.VarChar(150)
  academicYear String? @db.VarChar(50)

  occupation String? @db.VarChar(150)
  workField  String? @db.VarChar(150)

  ageRange RoommateAgeRange?

  preferredMinRent Int? @db.UnsignedInt
  preferredMaxRent Int? @db.UnsignedInt

  preferredRoomType RoomType?

  preferredCity        String? @db.VarChar(100)
  preferredGovernorate String? @db.VarChar(100)

  interests Json?

  sleepSchedule  RoommateSleepSchedule?
  studyFrequency RoommateStudyFrequency?

  cleanlinessLevel RoommateCleanlinessLevel?

  smokingStatus    RoommateSmokingStatus?
  smokingTolerance RoommateSmokingTolerance?

  guestPreference RoommateGuestPreference?
  privacyLevel    RoommatePrivacyLevel?

  cookingFrequency RoommateCookingFrequency?
  expenseStyle     RoommateExpenseStyle?
  conflictStyle    RoommateConflictStyle?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("roommate_profiles")
}

model UserPreference {
  id            Int    @id @default(autoincrement()) @db.UnsignedInt
  userId        Int    @db.UnsignedInt
  preferenceKey String @db.VarChar(50)
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, preferenceKey])
  @@index([userId])
  @@map("user_preferences")
}

model Verification {
  id              Int                @id @default(autoincrement()) @db.UnsignedInt
  userId          Int                @unique @db.UnsignedInt
  idFrontUrl      String             @db.VarChar(500)
  idBackUrl       String             @db.VarChar(500)
  selfieUrl       String             @db.VarChar(500)
  status          VerificationStatus @default(PENDING)
  rejectionReason String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("verifications")
}

model Category {
  id       Int       @id @default(autoincrement()) @db.UnsignedInt
  name     String    @db.VarChar(100)
  iconUrl  String?   @db.VarChar(500)
  slug     String    @unique @db.VarChar(100)
  listings Listing[]

  @@index([slug])
  @@map("categories")
}

model OTP {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  otp       String   @db.VarChar(100)
  userId    Int      @db.UnsignedInt
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otpTypes  OTPTypes

  @@index([userId])
  @@map("otps")
}

model Notification {
  id     Int @id @default(autoincrement()) @db.UnsignedInt
  userId Int @db.UnsignedInt

  type    NotificationType
  title   String           @db.VarChar(255)
  message String           @db.Text

  isRead Boolean   @default(false)
  readAt DateTime?

  emailStatus EmailDeliveryStatus @default(NOT_REQUESTED)
  emailSentAt DateTime?
  emailError  String?             @db.Text

  relatedEntity   String? @db.VarChar(50)
  relatedEntityId Int?    @db.UnsignedInt

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model Listing {
  id     Int  @id @default(autoincrement()) @db.UnsignedInt
  hostId Int  @db.UnsignedInt
  areaId Int? @db.UnsignedInt

  title       String @db.VarChar(255)
  description String @db.Text

  propertyType PropertyType
  roomType     RoomType

  streetName          String  @db.VarChar(255)
  buildingNumber      String? @db.VarChar(50)
  floorNumber         String? @db.VarChar(50)
  apartmentNumber     String? @db.VarChar(50)
  nearbyLandmark      String? @db.VarChar(255)
  arrivalInstructions String? @db.Text

  city        String @db.VarChar(100)
  governorate String @db.VarChar(100)
  country     String @default("Egypt") @db.VarChar(100)

  lat                    Decimal                 @db.Decimal(10, 8)
  lng                    Decimal                 @db.Decimal(11, 8)
  googleFormattedAddress String?                 @db.VarChar(500)
  googlePlaceId          String?                 @db.VarChar(255)
  locationPrivacy        LocationPrivacy         @default(APPROXIMATE)
  locationInsight        ListingLocationInsight?

  monthlyRent   Int      @db.UnsignedInt
  depositAmount Int      @default(0) @db.UnsignedInt
  currency      Currency @default(EGP)

  maxTenants Int @db.UnsignedInt
  bedrooms   Int @db.UnsignedInt
  beds       Int @db.UnsignedInt
  bathrooms  Int @db.UnsignedInt

  furnished         Boolean @default(true)
  utilitiesIncluded Boolean @default(false)
  internetIncluded  Boolean @default(false)
  minimumStayMonths Int     @default(1) @db.UnsignedInt
  maximumStayMonths Int?    @db.UnsignedInt

  availableFrom DateTime @db.Date

  genderPreference GenderPreference @default(ANY)
  smokingPolicy    SmokingPolicy    @default(NOT_ALLOWED)

  status          ListingStatus @default(DRAFT)
  rejectionReason String?       @db.Text

  submittedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?

  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  viewsCount Int       @default(0) @db.UnsignedInt

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  host       User      @relation(fields: [hostId], references: [id])
  area       Area?     @relation(fields: [areaId], references: [id], onDelete: SetNull)
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?      @db.UnsignedInt

  photos             ListingPhoto[]
  rooms              Room[]
  amenities          ListingAmenity[]
  availabilityBlocks AvailabilityBlock[]
  bookings           Booking[]
  reviews            Review[]
  vectorInsight      ListingVector?
  favorites          Favorite[]

  @@index([hostId])
  @@index([areaId])
  @@index([categoryId])
  @@index([city])
  @@index([governorate])
  @@index([status])
  @@index([monthlyRent])
  @@index([lat, lng])
  @@map("listings")
}

model ListingLocationInsight {
  id        Int @id @default(autoincrement()) @db.UnsignedInt
  listingId Int @unique @db.UnsignedInt

  provider String @default("overpass") @db.VarChar(50)

  radiusMeters Int @default(1000) @db.UnsignedInt

  nearbyServices Json?
  advantages     Json?
  disadvantages  Json?

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_location_insights")
}

model AvailabilityBlock {
  id          Int         @id @default(autoincrement()) @db.UnsignedInt
  listingId   Int         @db.UnsignedInt
  blockedDate DateTime    @db.Date
  reason      BlockReason @default(HOST_BLOCKED)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, blockedDate])
  @@index([listingId, blockedDate])
  @@map("availability_blocks")
}

model Area {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  name        String @db.VarChar(100)
  city        String @db.VarChar(100)
  governorate String @db.VarChar(100)
  country     String @default("Egypt") @db.VarChar(100)

  googlePlaceId String? @unique @db.VarChar(255)

  listings Listing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, city, governorate, country])
  @@index([city])
  @@index([governorate])
  @@map("areas")
}

model ListingPhoto {
  id           Int      @id @default(autoincrement()) @db.UnsignedInt
  listingId    Int      @db.UnsignedInt
  url          String   @db.VarChar(500)
  thumbnailUrl String?  @db.VarChar(500)
  sortOrder    Int      @default(0) @db.UnsignedInt
  isCover      Boolean  @default(false)
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  deleteUrl    String?  @db.VarChar(500)

  @@index([listingId])
  @@map("listing_photos")
}

model ListingAmenity {
  id         Int     @id @default(autoincrement()) @db.UnsignedInt
  listingId  Int     @db.UnsignedInt
  amenityKey String  @db.VarChar(50)
  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, amenityKey])
  @@index([listingId])
  @@map("listing_amenities")
}

model Favorite {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  userId    Int      @db.UnsignedInt
  listingId Int      @db.UnsignedInt
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("favorites")
}

model Booking {
  id        Int @id @default(autoincrement()) @db.UnsignedInt
  guestId   Int @db.UnsignedInt
  listingId Int @db.UnsignedInt

  preferredMoveInDate DateTime? @db.Date
  guestMessage        String?   @db.Text
  agreedAmount        Int?      @db.UnsignedInt
  roomId              Int?      @db.UnsignedInt
  selectedRoomName    String?   @db.VarChar(100)

  status BookingStatus @default(PENDING_HOST_APPROVAL)

  hostResponseNote   String? @db.Text
  rejectionReason    String? @db.Text
  cancellationReason String? @db.Text

  disputeReason        String?               @db.VarChar(100)
  disputeDescription   String?               @db.Text
  disputeResolution    String?               @db.Text
  disputeConversations DisputeConversation[]

  acceptedAt        DateTime?
  approvedAt        DateTime?
  paymentExpiresAt  DateTime?
  confirmedAt       DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  completedAt       DateTime?
  disputedAt        DateTime?
  disputeResolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Relations
  guest     User     @relation(fields: [guestId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  room      Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)

  review Review[]

  // هنسيب العلاقات دي مؤقتًا لأن Models موجودة حاليًا
  payment Payment?

  @@index([guestId])
  @@index([listingId])
  @@index([roomId])
  @@index([status])
  @@map("bookings")
}

model Room {
  id            Int      @id @default(autoincrement()) @db.UnsignedInt
  apartmentId   Int      @db.UnsignedInt
  roomNumber    Int      @db.UnsignedInt
  roomName      String   @db.VarChar(100)
  capacity      Int      @db.UnsignedInt
  occupiedCount Int      @default(0) @db.UnsignedInt
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  apartment Listing     @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  images    RoomImage[]
  bookings  Booking[]

  @@unique([apartmentId, roomNumber])
  @@index([apartmentId])
  @@map("rooms")
}

model RoomImage {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  roomId    Int      @db.UnsignedInt
  imageUrl  String   @db.VarChar(500)
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("room_images")
}

model Payment {
  id        Int @id @default(autoincrement()) @db.UnsignedInt
  bookingId Int @unique @db.UnsignedInt

  // Paymob specific fields
  paymobOrderId       String? @unique @db.VarChar(255)
  paymobTransactionId String? @unique @db.VarChar(255)

  // قيمة الإيجار الأساسية وقت الدفع
  rentAmount Int @default(0) @db.UnsignedInt

  // مبلغ التأمين وقت الدفع
  securityDepositAmount Int @default(0) @db.UnsignedInt

  // إجمالي المبلغ المدفوع من المغترب
  // إيجار + تأمين + رسوم المنصة
  amount Int @db.UnsignedInt

  // رسوم المنصة التي دفعها المغترب
  platformFee Int @default(0) @db.UnsignedInt

  // المبلغ المستحق لصاحب السكن عند الاستلام الطبيعي
  hostPayoutAmount Int @default(0) @db.UnsignedInt

  // المبلغ الذي تم رده للمغترب بعد حسم النزاع
  guestRefundAmount Int @default(0) @db.UnsignedInt

  // التعويض الذي أخذه صاحب السكن بعد حسم النزاع
  hostCompensationAmount Int @default(0) @db.UnsignedInt

  currency String @default("EGP") @db.VarChar(3)

  status PaymentStatus @default(PENDING)

  paymentMethod String? @db.VarChar(50) // card, fawry, wallet
  refundReason  String? @db.Text

  paidAt     DateTime?
  heldAt     DateTime?
  releasedAt DateTime?
  refundedAt DateTime?
  settledAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([paymobOrderId])
  @@index([paymobTransactionId])
  @@map("payments")
}

model Review {
  id         Int        @id @default(autoincrement()) @db.UnsignedInt
  bookingId  Int        @db.UnsignedInt
  reviewerId Int        @db.UnsignedInt
  listingId  Int?       @db.UnsignedInt
  reviewedId Int?       @db.UnsignedInt
  type       ReviewType

  // التقييم العام من 1 إلى 5 نجوم
  rating Int @db.UnsignedInt

  // تستخدم فقط مع تقييم السكن
  cleanliness Int? @db.UnsignedInt
  location    Int? @db.UnsignedInt
  accuracy    Int? @db.UnsignedInt
  value       Int? @db.UnsignedInt

  // النص الذي يكتب فيه المستخدم رأيه
  comment String? @db.Text

  isVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id])
  reviewer User     @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  reviewed User?    @relation("ReviewsReceived", fields: [reviewedId], references: [id])
  listing  Listing? @relation(fields: [listingId], references: [id])

  @@unique([bookingId, type])
  @@index([reviewerId])
  @@index([reviewedId])
  @@index([listingId])
  @@index([type])
  @@map("reviews")
}

model Conversation {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  guestId   Int      @db.UnsignedInt
  hostId    Int      @db.UnsignedInt
  listingId Int      @db.UnsignedInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guest   User    @relation("GuestConversations", fields: [guestId], references: [id], onDelete: Cascade)
  host    User    @relation("HostConversations", fields: [hostId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([guestId, hostId, listingId])
  @@index([guestId])
  @@index([hostId])
  @@index([listingId])
  @@map("conversations")
}

model Message {
  id             Int       @id @default(autoincrement()) @db.UnsignedInt
  conversationId Int       @db.UnsignedInt
  senderId       Int       @db.UnsignedInt
  content        String    @db.Text
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model DisputeConversation {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  bookingId       Int                    @db.UnsignedInt
  participantId   Int                    @db.UnsignedInt
  participantType DisputeParticipantType

  isClosed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking     Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  participant User    @relation("DisputeConversationParticipant", fields: [participantId], references: [id], onDelete: Cascade)

  messages DisputeMessage[]

  @@unique([bookingId, participantType])
  @@index([bookingId])
  @@index([participantId])
  @@map("dispute_conversations")
}

model DisputeMessage {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  conversationId Int @db.UnsignedInt
  senderId       Int @db.UnsignedInt

  content String @db.Text

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  conversation DisputeConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation("DisputeMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("dispute_messages")
}

model ListingVector {
  id        Int @id @default(autoincrement()) @db.UnsignedInt
  listingId Int @unique @db.UnsignedInt

  // Stores the stringified float array (e.g., "[0.012, -0.234, ...]")
  // Google's text-embedding-004 model generates 768 dimensions
  vectorText Json

  // It's highly beneficial to cache the raw text chunk used to generate the vector
  textChunk String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation back to your main Listing table
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_vectors")
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    Int? // Optional: link to your Student/User table if you have one
  isDeleted Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  role      String // Custom validation in code: "user" | "model"
  text      String   @db.Text // Text type to handle long AI or context strings
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

enum UserRole {
  GUEST
  HOST
  ADMIN
}

enum GenderPreference {
  MALE
  FEMALE
  ANY
}

enum SmokingPolicy {
  ALLOWED
  NOT_ALLOWED
}

enum LocationPrivacy {
  EXACT
  APPROXIMATE
}

enum Currency {
  EGP
}

enum ListingStatus {
  ACTIVE
  DRAFT
  PENDING_APPROVAL
  APPROVED
  RESERVED
  REJECTED
  INACTIVE
  SUSPENDED
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
  STUDIO
  OTHER
}

enum RoomType {
  ENTIRE_PLACE
  PRIVATE_ROOM
  SHARED_ROOM
}

enum BookingStatus {
  PENDING_HOST_APPROVAL
  PENDING_PAYMENT
  CHECK_IN_PENDING
  DISPUTED
  DISPUTE_RESOLVED_FOR_HOST
  COMPLETED
  REJECTED
  CANCELED
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  CANCELLED_AFTER_DISPUTE
  REFUNDED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum BlockReason {
  BOOKED
  HOST_BLOCKED
  MAINTENANCE
}

enum NotificationType {
  USER_VERIFICATION_APPROVED
  USER_VERIFICATION_REJECTED
  USER_VERIFICATION_NEEDS_CHANGES

  LISTING_VERIFICATION_APPROVED
  LISTING_VERIFICATION_REJECTED
  LISTING_VERIFICATION_NEEDS_CHANGES

  BOOKING_REQUESTED
  BOOKING_APPROVED
  BOOKING_REJECTED
  PAYMENT_REQUIRED
  PAYMENT_CONFIRMED
}

enum EmailDeliveryStatus {
  NOT_REQUESTED
  PENDING
  SENT
  FAILED
}

enum ReviewType {
  // المغترب يقيّم السكن نفسه
  GUEST_TO_LISTING

  // المغترب يقيّم تعامل صاحب السكن
  GUEST_TO_HOST

  // صاحب السكن يقيّم المغترب
  HOST_TO_GUEST
}

enum OTPTypes {
  EMAIL_CONFIRMATION
  RESET_PASSWORD
}

enum genderTypes {
  male
  female
}

enum VerificationStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum DisputeParticipantType {
  GUEST
  HOST
}

enum RoommateOccupationType {
  STUDENT
  EMPLOYEE
  FREELANCER
  OTHER
}

enum RoommateAgeRange {
  UNDER_18
  AGE_18_20
  AGE_21_23
  AGE_24_26
  AGE_27_30
  ABOVE_30
}

enum RoommateSleepSchedule {
  EARLY
  NORMAL
  LATE
  VARIABLE
}

enum RoommateCleanlinessLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum RoommateSmokingStatus {
  NON_SMOKER
  SMOKER
  OCCASIONAL
}

enum RoommateSmokingTolerance {
  NEVER
  OUTSIDE_ONLY
  OK
}

enum RoommateGuestPreference {
  NO_GUESTS
  WITH_NOTICE
  SOMETIMES
  OFTEN
}

enum RoommatePrivacyLevel {
  HIGH
  MEDIUM
  SOCIAL
}

enum RoommateStudyFrequency {
  RARELY
  SOMETIMES
  OFTEN
}

enum RoommateCookingFrequency {
  RARELY
  SOMETIMES
  DAILY
}

enum RoommateExpenseStyle {
  EQUAL
  BY_USAGE
  AGREEMENT
}

enum RoommateConflictStyle {
  DIRECT_CALM
  INFORM_HOST
  AVOID
}
